# ─────────────────────────────────────────────
# OpenAI (Chat / AI Agent)
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─────────────────────────────────────────────
# Mailchimp
# ─────────────────────────────────────────────
# API Key: https://mailchimp.com/help/about-api-keys/
MAILCHIMP_API_KEY=your-mailchimp-api-key

# Audience / List ID: Mailchimp → Audience → Settings → Audience name and defaults
MAILCHIMP_AUDIENCE_ID=abc1234567

# Datacenter prefix aus dem API Key (z.B. "us21")
# Der Prefix ist der Teil nach dem letzten Bindestrich im API Key: xxxxx-us21 → us21
MAILCHIMP_SERVER_PREFIX=us21
